{
  "name": "ultimate-dark-tower",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Ultimate Dark Tower monorepo — core library, display/board renderers, creator, relay, and companion apps.",
  "author": "ChessMess",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ChessMess/UltimateDarkTower.git"
  },
  "bugs": {
    "url": "https://github.com/ChessMess/UltimateDarkTower/issues"
  },
  "homepage": "https://github.com/ChessMess/UltimateDarkTower#readme",
  "engines": {
    "node": ">=22.13.0",
    "pnpm": ">=11.0.0"
  },
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "postinstall": "pnpm --filter @udtc/engine build",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "dev:creator": "pnpm --filter @udtc/creator dev",
    "dev:player": "pnpm --filter @udtc/player dev",
    "dev:digital": "pnpm --filter ultimatedarktowerdigital dev",
    "dev:seed": "pnpm --filter ultimatedarktowerseed dev",
    "dev:sync": "pnpm --filter @dark-tower-sync/client dev",
    "dev:controller": "pnpm --filter ultimatedarktowercontroller dev",
    "dev:game": "pnpm --filter ultimatedarktowergame dev",
    "dev:display": "pnpm --filter ultimatedarktowerdisplay dev:example",
    "dev:board": "pnpm --filter ultimatedarktowerboard dev:example",
    "dev:relay-cli": "pnpm --filter ultimatedarktowerrelay-cli build && pnpm --filter ultimatedarktowerrelay-cli start",
    "dev:relay-electron": "pnpm --filter ultimatedarktowerrelay-electron dev",
    "dev:mcp-server": "pnpm --filter mcp-server-return-to-dark-tower dev",
    "lint": "eslint .",
    "validate:nodes": "node scripts/creator/validate-node-catalog.mjs",
    "pages:landing": "node scripts/pages/build-landing.mjs",
    "preview:site": "node scripts/pages/preview-site.mjs",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,cjs,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,mjs,cjs,json,md,css}\"",
    "ci": "pnpm validate:nodes && pnpm lint && pnpm format:check && pnpm build && pnpm typecheck && pnpm test",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "pnpm -r build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.1",
    "@eslint/js": "^9.39.5",
    "@types/node": "^22.0.0",
    "eslint": "^9.39.5",
    "eslint-plugin-react-hooks": "^7.1.0",
    "eslint-plugin-react-refresh": "^0.5.0",
    "globals": "^17.0.0",
    "prettier": "^3.8.0",
    "typescript": "catalog:",
    "typescript-eslint": "^8.64.0"
  }
}
