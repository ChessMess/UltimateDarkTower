{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "include": ["src/**/*"],
  // This package publishes to npm, so tests and their scaffolding must stay out of
  // dist/ — they are excluded from the build, not just untyped.
  "exclude": ["node_modules", "dist", "src/**/*.test.ts", "src/test-support/**"]
}
