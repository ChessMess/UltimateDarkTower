{
  "name": "mcp-server-return-to-dark-tower",
  "version": "1.0.2",
  "private": false,
  "description": "MCP server for controlling the Return to Dark Tower board game tower via Bluetooth",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mcp-server-dark-tower": "dist/index.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ChessMess/UltimateDarkTower.git",
    "directory": "apps/mcp-server"
  },
  "homepage": "https://github.com/ChessMess/UltimateDarkTower/tree/main/apps/mcp-server#readme",
  "bugs": {
    "url": "https://github.com/ChessMess/UltimateDarkTower/issues"
  },
  "author": "Chris Koerner-Zeller",
  "scripts": {
    "build": "tsc && rm -rf dist/game-content && cp -R src/game-content dist/game-content",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "inspect": "pnpm run build && npx @modelcontextprotocol/inspector node dist/index.js --stdio-only",
    "inspect:dev": "npx @modelcontextprotocol/inspector tsx src/index.ts --stdio-only",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "return-to-dark-tower",
    "bluetooth",
    "ble",
    "board-game",
    "claude",
    "ai"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.0",
    "express": "^4.21.0",
    "ultimatedarktower": "workspace:^",
    "ultimatedarktowerdata": "workspace:*",
    "zod": "^3.25.0"
  },
  "peerDependencies": {
    "@stoprocent/noble": "^2.0.0"
  },
  "peerDependenciesMeta": {
    "@stoprocent/noble": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
