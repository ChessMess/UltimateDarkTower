{
  "name": "mcp-server-return-to-dark-tower",
  "version": "0.1.0",
  "description": "MCP server for controlling the Return to Dark Tower board game tower via Bluetooth",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mcp-server-dark-tower": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint src/ && prettier --check src/",
    "lint:fix": "eslint src/ --fix && prettier --write src/",
    "test": "echo \"No tests yet\" && exit 0"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "return-to-dark-tower",
    "bluetooth",
    "ble",
    "board-game",
    "claude",
    "ai"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.0",
    "express": "^4.21.0",
    "ultimatedarktower": "^2.0.0",
    "zod": "^3.25.0"
  },
  "peerDependencies": {
    "@stoprocent/noble": "^2.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "@eslint/js": "^9.0.0",
    "typescript-eslint": "^8.0.0",
    "prettier": "^3.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
