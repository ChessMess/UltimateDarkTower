# Entries already covered by the root .gitignore (node_modules, dist,
# *.tsbuildinfo, .env/.env.local/.env.{development,test,production}.local,
# .DS_Store, *.log) are intentionally not repeated here — only what's
# genuinely specific to this app.

# Broader than root's enumerated .env.{development,test,production}.local —
# covers any environment name (e.g. .env.staging.local).
.env.*.local

# OS files
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# Copyrighted materials (not for distribution)
RtDT_Rulebook.pdf
