{
  "name": "ultimatedarktowerdigital",
  "version": "0.0.3",
  "private": true,
  "type": "module",
  "description": "Play a solo base game of Return to Dark Tower in the browser — software tower emulator, digital game board, and digital player boards composed from the UDT library family.",
  "author": "ChessMess",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "dev:digital": "pnpm run dev",
    "build": "tsc --build && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --build --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "ci": "pnpm lint && pnpm typecheck && pnpm test && pnpm build"
  },
  "dependencies": {
    "@dimforge/rapier3d-compat": "catalog:",
    "gsap": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "three": "catalog:",
    "ultimatedarktower": "workspace:^",
    "ultimatedarktowerdata": "workspace:^",
    "ultimatedarktowerboard": "workspace:^",
    "ultimatedarktowerdisplay": "workspace:^",
    "zustand": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@types/three": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "jsdom": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ChessMess/UltimateDarkTower.git",
    "directory": "apps/digital"
  }
}
