{
  "name": "ultimatedarktowerdigital",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Play a solo base game of Return to Dark Tower in the browser — software tower emulator, digital game board, and digital player boards composed from the UDT library family.",
  "author": "ChessMess",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "ci": "npm run lint && npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "@dimforge/rapier3d-compat": "^0.19.3",
    "gsap": "^3.15.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "three": "^0.185.0",
    "ultimatedarktower": "workspace:^",
    "ultimatedarktowerdata": "workspace:^",
    "ultimatedarktowerboard": "workspace:^",
    "ultimatedarktowerdisplay": "workspace:^",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.21",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@types/three": "^0.185.0",
    "@vitejs/plugin-react": "^6.0.0",
    "jsdom": "^25.0.0",
    "prettier": "^3.8.0",
    "typescript": "catalog:",
    "vite": "^8.0.0",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=22.13.0"
  }
}
