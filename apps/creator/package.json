{
  "name": "@udtc/creator",
  "version": "0.2.3",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "pnpm --filter @udtc/engine build",
    "dev": "vite",
    "dev:creator": "pnpm run dev",
    "build": "tsc --build && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --build",
    "lint": "eslint .",
    "pretest": "pnpm --filter @udtc/engine build",
    "test": "vitest run",
    "test:watch": "vitest",
    "ci": "pnpm lint && pnpm typecheck && pnpm test && pnpm build"
  },
  "dependencies": {
    "@dagrejs/dagre": "^1.0.0",
    "@dimforge/rapier3d-compat": "catalog:",
    "@udtc/adapters": "workspace:*",
    "@udtc/card-render": "workspace:*",
    "@udtc/engine": "workspace:*",
    "@udtc/scenario-store": "workspace:*",
    "@udtc/schema": "workspace:*",
    "@udtc/theme": "workspace:*",
    "@xyflow/react": "^12.0.0",
    "gsap": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "three": "catalog:",
    "ultimatedarktower": "workspace:^",
    "ultimatedarktowerboard": "workspace:^",
    "ultimatedarktowerdisplay": "workspace:^",
    "zustand": "catalog:"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "ajv": "catalog:",
    "ajv-formats": "catalog:",
    "fake-indexeddb": "catalog:",
    "jsdom": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=22.13.0"
  },
