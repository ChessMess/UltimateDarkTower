{
  "name": "ultimatedarktowerrelay-cli",
  "version": "0.1.0",
  "description": "UltimateDarkTowerRelay CLI — headless relay daemon (fake BLE tower + WebSocket relay) for servers, Raspberry Pi, Docker, or an always-on host.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch",
    "start": "node dist/index.js",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "ultimatedarktowerrelay-core": "*",
    "ultimatedarktowerrelay-shared": "*",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/ws": "^8.5.10"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
