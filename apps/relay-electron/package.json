{
  "name": "ultimatedarktowerrelay-electron",
  "version": "0.1.2",
  "private": true,
  "description": "UltimateDarkTowerRelay desktop operator console — Electron GUI over the relay core (selectable emulator/mock/real tower source, WebSocket relay, status, manual controls).",
  "main": ".vite/build/main.js",
  "scripts": {
    "dev": "electron-forge start",
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "rebuild": "electron-rebuild -f -w @stoprocent/bleno,@stoprocent/noble",
    "test": "vitest run --passWithNoTests"
  },
  "author": "ChessMess",
  "license": "MIT",
  "dependencies": {
    "@stoprocent/bleno": "^0.12.4",
    "@stoprocent/noble": "^2.5.7",
    "electron-squirrel-startup": "^1.0.1",
    "ultimatedarktower": "workspace:^",
    "ultimatedarktowerrelay-core": "workspace:^",
    "ultimatedarktowerrelay-shared": "workspace:^",
    "ws": "catalog:"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.2",
    "@electron-forge/maker-deb": "^7.11.2",
    "@electron-forge/maker-dmg": "^7.11.2",
    "@electron-forge/maker-zip": "^7.11.2",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.2",
    "@electron-forge/plugin-vite": "^7.11.2",
    "@electron/rebuild": "^4.0.4",
    "@types/electron-squirrel-startup": "^1.0.2",
    "electron": "^42.7.0",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ChessMess/UltimateDarkTower.git",
    "directory": "apps/relay-electron"
  }
}
