{
  "name": "@dark-tower-sync/client",
  "version": "0.3.1",
  "description": "DarkTowerSync browser client — receives relayed tower commands over WebSocket and replays them on the player's physical tower via Web Bluetooth.",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "preview": "vite preview",
    "test": "vitest run",
    "typecheck": "tsc --build --noEmit",
    "clean": "rm -rf dist"
  },
  "author": "ChessMess",
  "license": "MIT",
  "dependencies": {
    "@dimforge/rapier3d-compat": "catalog:",
    "gsap": "catalog:",
    "three": "catalog:",
    "ultimatedarktower": "workspace:^",
    "ultimatedarktowerdisplay": "workspace:^",
    "ultimatedarktowerrelay-client": "workspace:^",
    "ultimatedarktowerrelay-shared": "workspace:^"
  },
  "devDependencies": {
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ChessMess/UltimateDarkTower.git",
    "directory": "apps/sync"
  }
}
