{
  "name": "@dark-tower-sync/host",
  "version": "0.1.0",
  "description": "DarkTowerSync host — fake BLE tower peripheral and WebSocket relay server.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch",
    "start": "node dist/index.js",
    "clean": "rm -rf dist *.tsbuildinfo",
    "capture": "ts-node --project tsconfig.capture.json scripts/captureTower.ts",
    "analyze": "ts-node --project tsconfig.capture.json scripts/analyzeLogs.ts"
  },
  "author": "ChessMess",
  "license": "MIT",
  "dependencies": {
    "@dark-tower-sync/shared": "*",
    "@stoprocent/bleno": "^0.12.4",
    "@stoprocent/noble": "^2.3.10",
    "ultimatedarktower": "^2.1.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/ws": "^8.5.10"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
