{
  "name": "ultimatedarktowerdata",
  "version": "2.0.1",
  "description": "Return to Dark Tower reference data — board locations, foes, heroes, monuments, box inventory, and seed parsing. Zero dependencies.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./board": {
      "types": "./dist/board/index.d.ts",
      "default": "./dist/board/index.js"
    },
    "./seed": {
      "types": "./dist/seed/index.d.ts",
      "default": "./dist/seed/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc --build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "clean": "rm -rf dist *.tsbuildinfo",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "ReturnToDarkTower",
    "BoardGame",
    "Tower",
    "RestorationGames",
    "UltimateDarkTower"
  ],
  "author": "ChessMess",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ChessMess/UltimateDarkTower.git",
    "directory": "packages/game-data"
  },
  "bugs": {
    "url": "https://github.com/ChessMess/UltimateDarkTower/issues"
  },
  "homepage": "https://github.com/ChessMess/UltimateDarkTower/tree/main/packages/game-data#readme",
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/chessmess"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "catalog:",
    "vitest": "catalog:"
  }
}
