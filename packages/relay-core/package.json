{
  "name": "ultimatedarktowerrelay-core",
  "version": "0.2.0",
  "description": "UltimateDarkTowerRelay core — headless BLE tower-emulator peripheral and WebSocket relay engine.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch",
    "typecheck": "tsc --noEmit",
    "prepack": "npm run clean && npm run build",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "keywords": [
    "ReturnToDarkTower",
    "BoardGame",
    "Tower",
    "RestorationGames",
    "BLE",
    "bluetooth",
    "WebSocket",
    "relay",
    "emulator",
    "UltimateDarkTower"
  ],
  "author": "ChessMess",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ChessMess/UltimateDarkTower.git",
    "directory": "packages/relay-core"
  },
  "bugs": {
    "url": "https://github.com/ChessMess/UltimateDarkTower/issues"
  },
  "homepage": "https://github.com/ChessMess/UltimateDarkTower/tree/main/packages/relay-core#readme",
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/chessmess"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "ultimatedarktowerrelay-shared": "workspace:^",
    "@stoprocent/bleno": "^0.12.4",
    "ultimatedarktower": "workspace:^",
    "ultimatedarktowerdata": "workspace:*",
    "ws": "^8.18.0"
  },
  "optionalDependencies": {
    "@stoprocent/noble": "^2.3.10"
  },
  "devDependencies": {
    "@types/ws": "^8.5.10"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
