{
  "name": "ultimatedarktowerrelay-core",
  "version": "1.1.0",
  "description": "UltimateDarkTowerRelay core — headless BLE tower-emulator peripheral and WebSocket relay engine.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./logAnalysis": {
      "types": "./dist/logAnalysis.d.ts",
      "default": "./dist/logAnalysis.js"
    },
    "./eventLog": {
      "types": "./dist/eventLog.d.ts",
      "default": "./dist/eventLog.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "keywords": [
    "ReturnToDarkTower",
    "BoardGame",
    "Tower",
    "RestorationGames",
    "BLE",
    "bluetooth",
    "WebSocket",
    "relay",
    "emulator",
    "UltimateDarkTower"
  ],
  "author": "ChessMess",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ChessMess/UltimateDarkTower.git",
    "directory": "packages/relay-core"
  },
  "bugs": {
    "url": "https://github.com/ChessMess/UltimateDarkTower/issues"
  },
  "homepage": "https://github.com/ChessMess/UltimateDarkTower/tree/main/packages/relay-core#readme",
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/chessmess"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "ultimatedarktowerrelay-shared": "workspace:^",
    "@stoprocent/bleno": "^0.12.4",
    "ultimatedarktower": "workspace:^",
    "ultimatedarktowerdata": "workspace:^",
    "ws": "catalog:"
  },
  "optionalDependencies": {
    "@stoprocent/noble": "^2.5.7"
  },
  "devDependencies": {
    "@types/ws": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "sideEffects": false
}
