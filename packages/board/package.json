{
  "name": "ultimatedarktowerboard",
  "version": "0.3.0",
  "description": "Composable state + text/2D/3D renderers for the Return to Dark Tower game board. The 3D board is a ScenePlugin for ultimatedarktowerdisplay.",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.esm.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs"
    },
    "./plugin": {
      "types": "./dist/plugin/index.d.ts",
      "import": "./dist/plugin.esm.js",
      "require": "./dist/plugin.cjs"
    },
    "./stage": {
      "types": "./dist/stage/index.d.ts",
      "import": "./dist/stage.esm.js",
      "require": "./dist/stage.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=7.0.0"
  },
  "license": "MIT",
  "author": "ChessMess",
  "scripts": {
    "dev": "vite",
    "dev:example": "vite --config vite.example.config.ts",
    "build": "vite build && tsc --emitDeclarationOnly",
    "build:example": "vite build --config vite.example.config.ts",
    "preview:example": "vite preview --config vite.example.config.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write 'src/**/*.ts' '__tests__/**/*.ts'",
    "clean": "rimraf dist",
    "promote-token-art": "node scripts/promote-token-art.mjs",
    "ci": "npm run typecheck && npm run lint && npm run test && npm run build"
  },
  "peerDependencies": {
    "ultimatedarktower": "^5.0.0",
    "ultimatedarktowerdisplay": "^0.9.0 || ^0.10.0",
    "three": "^0.170.0",
    "gsap": "^3.12.0"
  },
  "peerDependenciesMeta": {
    "ultimatedarktowerdisplay": {
      "optional": true
    },
    "three": {
      "optional": true
    },
    "gsap": {
      "optional": true
    }
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/three": "^0.185.0",
    "gsap": "^3.15.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "prettier": "^3.2.0",
    "rimraf": "^5.0.0",
    "three": "^0.185.0",
    "ts-jest": "^29.1.0",
    "typescript": "catalog:",
    "ultimatedarktower": "workspace:^",
    "ultimatedarktowerdisplay": "workspace:^",
    "vite": "^8.0.0"
  },
  "keywords": [
    "ReturnToDarkTower",
    "BoardGame",
    "board",
    "tower-state",
    "UltimateDarkTower"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ChessMess/UltimateDarkTower.git",
    "directory": "packages/board"
  },
  "homepage": "https://github.com/ChessMess/UltimateDarkTower/tree/main/packages/board#readme",
  "bugs": {
    "url": "https://github.com/ChessMess/UltimateDarkTower/issues"
  }
}
