{
  "name": "ultimatedarktowerboard",
  "version": "1.0.0",
  "description": "Composable state + text/2D/3D renderers for the Return to Dark Tower game board. The 3D board is a ScenePlugin for ultimatedarktowerdisplay.",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.esm.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs"
    },
    "./plugin": {
      "types": "./dist/plugin/index.d.ts",
      "import": "./dist/plugin.esm.js",
      "require": "./dist/plugin.cjs"
    },
    "./stage": {
      "types": "./dist/stage/index.d.ts",
      "import": "./dist/stage.esm.js",
      "require": "./dist/stage.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=22.13.0"
  },
  "license": "MIT",
  "author": "ChessMess",
  "scripts": {
    "dev": "vite",
    "dev:example": "vite --config vite.config.example.ts",
    "build": "vite build && tsc --emitDeclarationOnly && node scripts/check-three-free.mjs",
    "build:example": "vite build --config vite.config.example.ts",
    "preview:example": "vite preview --config vite.config.example.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "clean": "rm -rf dist",
    "promote-token-art": "node scripts/promote-token-art.mjs",
    "ci": "pnpm typecheck && pnpm lint && pnpm test && pnpm build"
  },
  "peerDependencies": {
    "ultimatedarktowerdisplay": "^1.0.0",
    "three": ">=0.185.0",
    "gsap": "^3.12.0"
  },
  "peerDependenciesMeta": {
    "ultimatedarktowerdisplay": {
      "optional": true
    },
    "three": {
      "optional": true
    },
    "gsap": {
      "optional": true
    }
  },
  "dependencies": {
    "zod": "^4.4.3",
    "ultimatedarktowerdata": "workspace:^"
  },
  "devDependencies": {
    "@types/three": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "gsap": "catalog:",
    "jsdom": "catalog:",
    "three": "catalog:",
    "typescript": "catalog:",
    "ultimatedarktowerdisplay": "workspace:^",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "keywords": [
    "ReturnToDarkTower",
    "BoardGame",
    "board",
    "tower-state",
    "UltimateDarkTower"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ChessMess/UltimateDarkTower.git",
    "directory": "packages/board"
  },
  "homepage": "https://github.com/ChessMess/UltimateDarkTower/tree/main/packages/board#readme",
  "bugs": {
    "url": "https://github.com/ChessMess/UltimateDarkTower/issues"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/chessmess"
  }
}
