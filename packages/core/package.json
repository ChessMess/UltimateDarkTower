{
  "name": "ultimatedarktower",
  "version": "6.0.0",
  "description": "This library provides functions to communicate with the bluetooth le enabled Tower that comes with Restoration Games Return To Dark Tower board game.",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "module": "dist/esm/index.mjs",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/esm/index.mjs",
      "require": "./dist/src/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist/src/**/*",
    "dist/esm/**/*",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ci": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist coverage",
    "watch": "tsc -watch",
    "build": "npm run clean && npm run typecheck && tsc && esbuild src/index.ts --bundle --format=esm --outfile=dist/esm/index.mjs --packages=external --banner:js=\"import{createRequire}from'module';const require=createRequire(import.meta.url);\"",
    "dev": "npm run watch",
    "ci": "npm run lint && npm run typecheck && npm run test:ci && npm run build",
    "prepack": "npm run ci",
    "prepublishOnly": "npm run prepack",
    "publish:check": "npm run ci",
    "size": "npm run build && du -sh dist/",
    "test:integration": "npx ts-node tests/integration/calibration.integration.ts",
    "test:integration:lights": "npx ts-node tests/integration/lights.integration.ts",
    "example:node": "npx ts-node examples/node/NodeExample.ts"
  },
  "keywords": [
    "ReturnToDarkTower",
    "BLE",
    "BoardGame",
    "Tower",
    "RestorationGames",
    "UltimateDarkTower",
    "bluetooth",
    "ble",
    "restoration-games"
  ],
  "author": "Chris Koerner-Zeller",
  "license": "MIT",
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/chessmess"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ChessMess/UltimateDarkTower.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/ChessMess/UltimateDarkTower/issues"
  },
  "homepage": "https://github.com/ChessMess/UltimateDarkTower/tree/main/packages/core#readme",
  "engines": {
    "node": ">=22.13.0"
  },
  "browserslist": [
    "defaults",
    "not IE 11"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "ultimatedarktowerdata": "workspace:^"
  },
  "peerDependencies": {
    "@stoprocent/noble": "^2.0.0"
  },
  "peerDependenciesMeta": {
    "@stoprocent/noble": {
      "optional": true
    }
  },
  "devDependencies": {
    "@stoprocent/noble": "^2.3.17",
    "@types/node": "catalog:",
    "@types/web-bluetooth": "^0.0.21",
    "@vitest/coverage-v8": "catalog:",
    "esbuild": "^0.28.1",
    "ts-node": "^10.9.2",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
