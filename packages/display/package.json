{
  "name": "ultimatedarktowerdisplay",
  "version": "1.0.1",
  "description": "Composable text, 2D, and 3D renderers for Return to Dark Tower tower state, with optional skull physics.",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs"
    },
    "./physics": {
      "types": "./dist/physics/index.d.ts",
      "import": "./dist/physics.esm.js",
      "require": "./dist/physics.cjs"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "!dist/**/*.map",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "docs"
  ],
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly",
    "build:example": "vite build --config vite.config.example.ts",
    "dev": "vite",
    "dev:example": "vite --open /example/index.html",
    "dev:display": "pnpm run dev:example",
    "test": "vitest run",
    "test:watch": "vitest --project unit",
    "test:coverage": "vitest run --project unit --coverage",
    "test:sequence-snapshots": "vitest run --project snapshots",
    "test:cjs-smoke": "node -e \"require('./dist/index.cjs'); require('./dist/physics.cjs')\"",
    "record-sequence-snapshots": "UPDATE_SNAPSHOTS=1 vitest run --project snapshots && prettier --write \"tests/sequenceSnapshots/__snapshots__/*.snap.json\"",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.example.json",
    "lint": "eslint .",
    "lint:fix": "eslint 'src/**/*.ts' 'tests/**/*.ts' 'example/**/*.ts' --fix",
    "clean": "rm -rf dist dist-example coverage",
    "ci": "pnpm typecheck && pnpm lint && pnpm test && pnpm build"
  },
  "peerDependencies": {
    "gsap": "^3.12.0",
    "three": ">=0.185.0",
    "ultimatedarktower": "^7.0.0",
    "@dimforge/rapier3d-compat": "^0.19.3"
  },
  "peerDependenciesMeta": {
    "three": {
      "optional": true
    },
    "gsap": {
      "optional": true
    },
    "@dimforge/rapier3d-compat": {
      "optional": true
    }
  },
  "devDependencies": {
    "@dimforge/rapier3d-compat": "catalog:",
    "@types/three": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "gsap": "catalog:",
    "three": "catalog:",
    "typescript": "catalog:",
    "ultimatedarktower": "workspace:^",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "keywords": [
    "ReturnToDarkTower",
    "BoardGame",
    "display",
    "tower-state",
    "DOM",
    "UltimateDarkTower"
  ],
  "author": "ChessMess",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ChessMess/UltimateDarkTower.git",
    "directory": "packages/display"
  },
  "bugs": {
    "url": "https://github.com/ChessMess/UltimateDarkTower/issues"
  },
  "homepage": "https://github.com/ChessMess/UltimateDarkTower/tree/main/packages/display#readme",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "dependencies": {
    "zod": "^4.4.3",
    "ultimatedarktowerdata": "workspace:^"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/chessmess"
  }
}
