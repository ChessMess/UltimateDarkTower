{
  "name": "ultimatedarktowerdisplay",
  "version": "0.11.0",
  "description": "Composable text, 2D, and 3D renderers for Return to Dark Tower tower state, with optional skull physics.",
  "type": "module",
  "main": "dist/index.cjs.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs.js"
    },
    "./physics": {
      "types": "./dist/physics/index.d.ts",
      "import": "./dist/physics.esm.js",
      "require": "./dist/physics.cjs.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "!dist/**/*.map",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "docs"
  ],
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly",
    "build:example": "vite build --config vite.config.example.ts",
    "dev": "vite",
    "dev:example": "vite --open /example/index.html",
    "test": "jest --config jest.config.cjs && jest --config jest.config.snapshots.cjs",
    "test:watch": "jest --config jest.config.cjs --watch",
    "test:coverage": "jest --config jest.config.cjs --coverage",
    "test:sequence-snapshots": "jest --config jest.config.snapshots.cjs",
    "record-sequence-snapshots": "UPDATE_SNAPSHOTS=1 jest --config jest.config.snapshots.cjs && prettier --write \"tests/sequenceSnapshots/__snapshots__/*.snap.json\"",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.example.json",
    "lint": "eslint .",
    "lint:fix": "eslint 'src/**/*.ts' 'tests/**/*.ts' 'example/**/*.ts' --fix",
    "clean": "rm -rf dist dist-example coverage",
    "ci": "npm run typecheck && npm run lint && npm test && npm run build",
    "prepublishOnly": "npm run ci"
  },
  "peerDependencies": {
    "gsap": "^3.12.0",
    "three": ">=0.185.0",
    "ultimatedarktower": "^4.0.0 || ^5.0.0 || ^6.0.0",
    "@dimforge/rapier3d-compat": "^0.19.3"
  },
  "peerDependenciesMeta": {
    "three": {
      "optional": true
    },
    "gsap": {
      "optional": true
    },
    "@dimforge/rapier3d-compat": {
      "optional": true
    }
  },
  "devDependencies": {
    "@dimforge/rapier3d-compat": "catalog:",
    "@types/jest": "^29.5.0",
    "@types/three": "catalog:",
    "gsap": "catalog:",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "three": "catalog:",
    "ts-jest": "^29.1.0",
    "typescript": "catalog:",
    "ultimatedarktower": "workspace:^",
    "vite": "catalog:"
  },
  "keywords": [
    "ReturnToDarkTower",
    "BoardGame",
    "display",
    "tower-state",
    "DOM",
    "UltimateDarkTower"
  ],
  "author": "ChessMess",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ChessMess/UltimateDarkTower.git",
    "directory": "packages/display"
  },
  "bugs": {
    "url": "https://github.com/ChessMess/UltimateDarkTower/issues"
  },
  "homepage": "https://github.com/ChessMess/UltimateDarkTower/tree/main/packages/display#readme",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "dependencies": {
    "zod": "^4.4.3",
    "ultimatedarktowerdata": "workspace:^"
  }
}
