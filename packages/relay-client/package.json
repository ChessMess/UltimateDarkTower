{
  "name": "ultimatedarktowerrelay-client",
  "version": "0.2.0",
  "description": "UltimateDarkTowerRelay consumer SDK — connect to a relay host over WebSocket, receive decoded tower state, and report participant player actions. Framework-agnostic; browser or Node.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch",
    "prepack": "npm run clean && npm run build",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "keywords": [
    "ReturnToDarkTower",
    "BoardGame",
    "Tower",
    "RestorationGames",
    "WebSocket",
    "relay",
    "client",
    "SDK",
    "UltimateDarkTower"
  ],
  "dependencies": {
    "ultimatedarktowerrelay-shared": "^0.1.0",
    "ultimatedarktower": "^5.0.0"
  },
  "devDependencies": {
    "ws": "^8.18.0",
    "@types/ws": "^8.5.10"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "author": "ChessMess",
  "repository": {
    "type": "git",
    "url": "https://github.com/ChessMess/UltimateDarkTowerRelay.git",
    "directory": "packages/client"
  },
  "bugs": {
    "url": "https://github.com/ChessMess/UltimateDarkTowerRelay/issues"
  },
  "homepage": "https://github.com/ChessMess/UltimateDarkTowerRelay#readme",
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/chessmess"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
