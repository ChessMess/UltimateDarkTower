{
  "name": "ultimatedarktowerrelay-client",
  "version": "0.1.0",
  "description": "UltimateDarkTowerRelay consumer SDK — connect to a relay host over WebSocket, receive decoded tower state, and report participant player actions. Framework-agnostic; browser or Node.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/**/*"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "ultimatedarktowerrelay-shared": "*",
    "ultimatedarktower": "^4.1.0"
  },
  "devDependencies": {
    "ws": "^8.18.0",
    "@types/ws": "^8.5.10"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "author": "ChessMess",
  "engines": {
    "node": ">=18.0.0"
  }
}
