{
  "name": "ultimatedarktowerrelay-client",
  "version": "1.0.1",
  "description": "UltimateDarkTowerRelay consumer SDK — connect to a relay host over WebSocket, receive decoded tower state, and report participant player actions. Framework-agnostic; browser or Node.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "keywords": [
    "ReturnToDarkTower",
    "BoardGame",
    "Tower",
    "RestorationGames",
    "WebSocket",
    "relay",
    "client",
    "SDK",
    "UltimateDarkTower"
  ],
  "dependencies": {
    "ultimatedarktowerrelay-shared": "workspace:^",
    "ultimatedarktower": "workspace:^"
  },
  "devDependencies": {
    "ws": "catalog:",
    "@types/ws": "catalog:",
    "vitest": "catalog:"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "author": "ChessMess",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ChessMess/UltimateDarkTower.git",
    "directory": "packages/relay-client"
  },
  "bugs": {
    "url": "https://github.com/ChessMess/UltimateDarkTower/issues"
  },
  "homepage": "https://github.com/ChessMess/UltimateDarkTower/tree/main/packages/relay-client#readme",
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/chessmess"
  },
  "engines": {
    "node": ">=22.13.0"
  }
}
