{
  // Shared compiler flags for the browser-targeted renderer libraries
  // (packages/display, packages/board). Holds only non-path options so it can be
  // extended safely; each package keeps its own outDir/rootDir/declarationDir/
  // include/exclude (those resolve relative to the file that declares them).
  //
  // Intentionally does NOT extend tsconfig.base.json: these ship ES2020 + DOM
  // libs, and packages/display has pre-existing unused-symbol code that base's
  // noUnusedLocals/noUnusedParameters would reject.
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noEmit": false,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true
  }
}
